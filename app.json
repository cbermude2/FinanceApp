{\n  "expo": {\n    "name": "FinanceApp",\n    "slug": "finance-app",\n    "version": "1.0.0",\n    "assetBundlePatterns": [\n      "**/*"\n    ],\n    "ios": {\n      "supportsTabletMode": true\n    },\n    "android": {\n      "adaptiveIcon": {\n        "foregroundImage": "./assets/adaptive-icon.png",\n        "backgroundColor": "#ffffff"\n      }\n    },\n    "web": {\n      "favicon": "./assets/favicon.png"\n    },\n    "plugins": [\n      [\n        "expo-image-picker",\n        {\n          "photosPermission": "The app accesses your photos to attach transaction screenshots",\n          "cameraPermission": "The app accesses your camera for transaction screenshots"\n        }\n      ]\n    ]\n  }\n}